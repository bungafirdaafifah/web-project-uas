# Salin file ini jadi `.env`, lalu isi nilainya.
# cp .env.example .env

# Secret key Flask (session & flash). Ganti dengan string acak panjang.
SECRET_KEY=ganti_dengan_string_acak_yang_panjang

# Connection string Postgres Supabase.
# Ambil di: Supabase Dashboard -> Project Settings -> Database -> Connection string
#
# PENTING untuk serverless/Vercel: pakai "Connection pooling" (Transaction mode,
# port 6543), BUKAN direct connection (port 5432). Direct connection akan
# kehabisan koneksi di serverless.
#
# Format (transaction pooler):
#   postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
